# EditorConfig for Habitao
# https://editorconfig.org/

root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
max_line_length = 120
trim_trailing_whitespace = true

[*.{kt,kts}]
# Ktlint configuration
# https://pinterest.github.io/ktlint/latest/rules/configuration-ktlint/

# Disable function naming rule for Composable functions
# Composable functions should use PascalCase per Android/Compose conventions
ktlint_function_naming_ignore_when_annotated_with = Composable

# Standard Kotlin style settings
ij_kotlin_allow_trailing_comma = true
ij_kotlin_allow_trailing_comma_on_call_site = true

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.{xml,json,yaml,yml}]
indent_size = 2

[*.gradle.kts]
indent_size = 4

[{Makefile,*.mk}]
indent_style = tab

<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive icon foreground layer for Habitao.
    Depicts a bold checkmark enclosed in two concentric rings, symbolising
    consistent habit completion and progress tracking.
    Drawn within the 108 × 108 dp safe-zone canvas (inner 72 × 72 dp visible
    after the launcher shape mask is applied).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer decorative ring -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#CCFFFFFF"
        android:strokeWidth="2"
        android:pathData="M54,54 m-30,0 a30,30 0 1,0 60,0 a30,30 0 1,0 -60,0" />

    <!-- Inner decorative ring -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#99FFFFFF"
        android:strokeWidth="1.5"
        android:pathData="M54,54 m-22,0 a22,22 0 1,0 44,0 a22,22 0 1,0 -44,0" />

    <!-- Checkmark — thick, rounded stroke for Material 3 expressiveness -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M40,54 L50,64 L68,44" />

</vector>

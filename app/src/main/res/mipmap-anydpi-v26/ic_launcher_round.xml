<?xml version="1.0" encoding="utf-8"?>
<!--
    Round adaptive launcher icon for Habitao (Android 8.0 / API 26+).
    Identical to ic_launcher.xml — the adaptive-icon format already supports
    any shape mask, so both square and round launchers reference the same layers.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background" />
    <foreground android:drawable="@drawable/ic_launcher_foreground" />
    <monochrome android:drawable="@drawable/ic_launcher_foreground" />
</adaptive-icon>

<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive launcher icon for Habitao (Android 8.0 / API 26+).
    The system applies a launcher-defined shape mask (circle, squircle, etc.)
    to the 108 × 108 dp canvas.  Background and foreground layers are kept
    separate so the launcher can apply parallax and other visual effects.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background" />
    <foreground android:drawable="@drawable/ic_launcher_foreground" />
    <monochrome android:drawable="@drawable/ic_launcher_foreground" />
</adaptive-icon>
